# ============================================================
# SimpleFIN Bridge Credentials
# ============================================================

# 1. SETUP TOKEN — paste the one-time base64 token from
#    https://bridge.simplefin.org (Developer / Apps section).
#    Single use! After running `bun run claim` it becomes dead.
SIMPLEFIN_SETUP_TOKEN=

# 2. ACCESS URL — auto-populated by `bun run claim`.
#    Long-lived. Format:
#    https://USERNAME:PASSWORD@bridge.simplefin.org/simplefin
#    Treat like a credit card — anyone with this URL can read your
#    bank balances and transactions.
SIMPLEFIN_ACCESS_URL=
